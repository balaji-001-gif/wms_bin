		"html": "<style>\n\t@page {\n\t\tsize: 62mm 29mm;\n\t\tmargin: 2mm;\n\t}\n\tbody {\n\t\tfont-family: 'Helvetica Neue', Arial, sans-serif;\n\t\tmargin: 0;\n\t\tpadding: 0;\n\t\twidth: 58mm;\n\t\theight: 25mm;\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\talign-items: center;\n\t\tjustify-content: center;\n\t\ttext-align: center;\n\t}\n\t.warehouse {\n\t\tfont-size: 7pt;\n\t\tcolor: #555;\n\t\tmargin-bottom: 1mm;\n\t\ttext-transform: uppercase;\n\t\tletter-spacing: 0.5px;\n\t}\n\t.bin-name {\n\t\tfont-size: 14pt;\n\t\tfont-weight: 700;\n\t\tcolor: #000;\n\t\tmargin-bottom: 1mm;\n\t\tletter-spacing: 1px;\n\t}\n\t.barcode-wrapper {\n\t\tmargin: 0;\n\t\tpadding: 0;\n\t}\n\t.barcode-wrapper svg {\n\t\theight: 8mm;\n\t\twidth: auto;\n\t\tmax-width: 54mm;\n\t}\n\t.zone-rack {\n\t\tfont-size: 6pt;\n\t\tcolor: #888;\n\t\tmargin-top: 0.5mm;\n\t}\n</style>\n<div class=\"warehouse\">{{ doc.warehouse }}</div>\n<div class=\"bin-name\">{{ doc.name }}</div>\n<div class=\"barcode-wrapper\">{{ frappe.get_barcode_html(doc.name) | safe }}</div>\n<div class=\"zone-rack\">{{ doc.zone or '' }}{{ ' / ' if doc.zone and doc.rack else '' }}{{ doc.rack or '' }}</div>",
